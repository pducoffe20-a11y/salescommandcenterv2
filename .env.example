# Copy this file to .env.local for local development.
# Do not commit real secrets or tenant-specific credentials.

# Microsoft Graph / Entra ID (future integration)
VITE_MICROSOFT_GRAPH_CLIENT_ID=
VITE_MICROSOFT_GRAPH_TENANT_ID=
VITE_MICROSOFT_GRAPH_REDIRECT_URI=http://localhost:5173/auth/microsoft/callback
VITE_MICROSOFT_GRAPH_SCOPES=User.Read Mail.Read Calendars.Read offline_access

# Salesforce (future integration)
VITE_SALESFORCE_CLIENT_ID=
VITE_SALESFORCE_REDIRECT_URI=http://localhost:5173/auth/salesforce/callback
VITE_SALESFORCE_LOGIN_URL=https://login.salesforce.com
VITE_SALESFORCE_API_VERSION=v61.0

# Optional API proxy for server-side OAuth/token exchange when added.
VITE_INTEGRATIONS_API_BASE_URL=
